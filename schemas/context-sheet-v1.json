{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mabo-du/HOARD/schemas/context-sheet-v1.json",
  "title": "Context Sheet",
  "description": "A single archaeological context record produced by HOARD Phase 1 and consumed by StratiGraph",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "context_number",
    "type",
    "description",
    "interpretation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema contract version",
      "default": "1.0.0",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "source_file": {
      "type": "string",
      "description": "Original source filename"
    },
    "model": {
      "type": "string",
      "description": "Model used for extraction (e.g. glm-ocr, qwen3-vl)",
      "default": "glm-ocr"
    },
    "context_number": {
      "type": "string",
      "description": "Context number. Should use square brackets format [101] where possible, but bare numbers (47023) are accepted.",
      "examples": ["[101]", "[47023]", "47023"]
    },
    "type": {
      "type": "string",
      "description": "Context type",
      "examples": ["layer", "cut", "deposit", "fill", "structure"]
    },
    "description": {
      "type": "string",
      "description": "Sedimentological description",
      "examples": ["Dark greyish-brown silty loam. Moderately compact."]
    },
    "interpretation": {
      "type": "string",
      "description": "Archaeological interpretation",
      "examples": ["Topsoil / ploughsoil horizon."]
    },
    "period": {
      "type": "string",
      "description": "Chronological period assignment",
      "default": "Unknown",
      "examples": ["Roman", "medieval", "post-medieval", "undated"]
    },
    "cut_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contexts that cut this one",
      "default": []
    },
    "cuts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contexts this one cuts",
      "default": []
    },
    "fills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contexts that fill this one",
      "default": []
    },
    "filled_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contexts this one fills",
      "default": []
    },
    "same_as": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ],
      "description": "Equivalent context number",
      "default": null
    },
    "sketch_present": {
      "type": "boolean",
      "description": "Whether a sketch or section drawing exists for this context",
      "default": false
    },
    "finds": {
      "type": "array",
      "description": "Recovered finds from this context",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "description": "Find type (pottery, bone, flint, metal, CBM, glass, etc.)" },
          "qty": { "type": "integer", "description": "Quantity" },
          "period": { "type": "string", "description": "Chronological period" },
          "notes": { "type": "string", "description": "Additional notes" }
        },
        "required": ["type", "qty"]
      }
    },
    "samples": {
      "type": "array",
      "description": "Environmental samples from this context",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Sample identifier" },
          "type": { "type": "string", "description": "Sample type (bulk soil, flot, monolith, etc.)" },
          "notes": { "type": "string", "description": "Processing notes" }
        }
      }
    },
    "review_flags": {
      "type": "array",
      "description": "Low-confidence or ambiguous fields requiring human review",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "issue": { "type": "string" }
        }
      }
    }
  }
}
